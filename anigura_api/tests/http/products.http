#     "brand"        => "!null|max:100",
#     "scale"        => "max:20" // def null
# }


### Get specific product
GET {{baseUrl}}/products/{{productId}}
Accept: {{contentType}}


### Update product (Partial)
PATCH  {{baseUrl}}/products/{{productId}}
Content-Type: {{contentType}}

{
    "details": {
        "id_media": 11,
        "is_limited": true
    }
}


### Delete product
DELETE {{baseUrl}}/products/{{productId}}
Accept: {{contentType}}
