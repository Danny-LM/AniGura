# products.http
@baseUrl = http://localhost:8000
@contentType = application/json
@productId = 10


### List products
GET {{baseUrl}}/products
Accept: {{contentType}}


### Create product (manga)
POST {{baseUrl}}/products
Content-Type: {{contentType}}

{
    "id_franchise": 1,
    "product_type": "manga_volume",
    "name": "Frieren: Beyond Journey's End Vol. 1",
    "description": "First volume of the acclaimed manga series.",
    "price": 12.99,
    "stock": 25,
    "sku": "MNG-FRR-001",
    "details": {
        "id_publisher": 3,
        "id_media": 1,
        "volume": 1
    }
}

# "id_franchise" => "!null|num",
# "product_type" => "",
# "name"         => "!null|max:255",
# "description"  => "",
# "price"        => "!null|num",
# "discount"     => "num",
# "stock"        => "!null|num",
# "active"       => "bool",
# "sku"          => "max:60",
# "details"      => "!null" = {
#     "id_publisher" => "!null|num",
#     "id_media"     => "num", // def null
#     "volume"       => "num" // def null
# }


### Create product (setbox)
POST {{baseUrl}}/products
Content-Type: {{contentType}}

{
    "id_franchise": 7,
    "product_type": "setbox",
    "name": "Oshi no Ko Collector's Box",
    "description": "Limited collector's box including vol. 1-3, art cards and poster.",
    "price": 49.99,
    "stock": 15,
    "sku": "SET-ONK-001",
    "details": {
        "content": "Vol. 1-3 manga, exclusive art cards x5, B2 poster"
    }
}

# "id_franchise" => "!null|num",
