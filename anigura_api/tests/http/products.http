# "price"        => "!null|num",
# "discount"     => "num",
# "stock"        => "!null|num",
# "active"       => "bool",
# "sku"          => "max:60",
# "details"      => "!null" = {
#     "id_media"     => "num", // def null
#     "content"      => "", // def null
#     "is_limited"   => "bool" // def: false
# }


### Create product (figure)
POST {{baseUrl}}/products
Content-Type: {{contentType}}

{
    "id_franchise": 1,
    "product_type": "figure",
    "name": "Frieren 1/7 Scale Figure - Good Smile",
    "description": "Highly detailed 1/7 scale figure of Frieren in her iconic mage outfit.",
    "price": 89.99,
    "discount": 5.00,
    "stock": 10,
    "sku": "FIG-FRR-001",
    "details": {
        "brand": "Good Smile Company",
        "scale": "1/7"
    }
}

# "id_franchise" => "!null|num",
