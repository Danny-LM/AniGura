# orders.http
@baseUrl = http://localhost:8000
@contentType = application/json
@userId = 2
@adminToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwicm9sZSI6ImFkbWluIiwiaWF0IjoxNzczNzEyNzQ1LCJleHAiOjE3NzM3MTk5NDV9.yYLVTbtmwB0MRYVqGlRtN7-v8UhnauNBtV22UH3yuZI
@userToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6Miwicm9sZSI6InVzZXIiLCJpYXQiOjE3NzM3MTI2OTAsImV4cCI6MTc3MzcxOTg5MH0.ZpOYAo5raYv0wkStyZPUMxz9tSBZOalKpgdnlrVQfy8


## Setup — agregar items al carrito primero
POST {{baseUrl}}/cart/{{userId}}
Content-Type: {{contentType}}
Authorization: Bearer {{userToken}}

{
    "id_product": 1,
    "quantity": 2
}

### Response
// {"status":"success","code":201,"msg":"Item added to cart","data":null,"timestamp":"2026-03-17 02:05:56"}


## Setup — segundo item
POST {{baseUrl}}/cart/{{userId}}
Content-Type: {{contentType}}
Authorization: Bearer {{userToken}}

{
    "id_product": 11,
    "quantity": 1
}

### Response
// {"status":"success","code":201,"msg":"Item added to cart","data":null,"timestamp":"2026-03-17 02:06:07"}


## Create order — success
POST {{baseUrl}}/orders/{{userId}}
Content-Type: {{contentType}}
Authorization: Bearer {{userToken}}

{
    "id_address": 7
}

### Response
// {"status":"success","code":201,"msg":"Order created successfully","data":{"id":1},"timestamp":"2026-03-17 02:14:20"}

## Get cart — debe estar vacío después de la orden
GET {{baseUrl}}/cart/{{userId}}
Authorization: Bearer {{userToken}}

### Response
// {"status":"success","code":200,"msg":"Request success","data":[],"timestamp":"2026-03-17 02:14:27"}


## Get user orders
GET {{baseUrl}}/orders/{{userId}}
Authorization: Bearer {{userToken}}

### Response
// {"status":"success","code":200,"msg":"Request success","data":{"info":{"total":1,"pages":1,"current":1,"next":null,"prev":null},"results":[{"id":1,"id_user":2,"shipping_addr":"Work,789 Office Ave,Guadalajara,Jalisco,44150","total_amount":"124.46","status":"pending","created_at":"2026-03-17 02:14:20","updated_at":"2026-03-17 02:14:20"}]},"timestamp":"2026-03-17 02:14:34"}


## Get order with details
GET {{baseUrl}}/orders/{{userId}}/1
Authorization: Bearer {{userToken}}

### Response
// {"status":"success","code":200,"msg":"Request success","data":{"id":1,"id_user":2,"shipping_addr":"Work,789 Office Ave,Guadalajara,Jalisco,44150","total_amount":"124.46","status":"pending","created_at":"2026-03-17 02:14:20","updated_at":"2026-03-17 02:14:20","details":[{"id":1,"id_order":1,"id_product":1,"quantity":3,"unit_price":"12.99","name":"Frieren: Beyond Journey's End Vol. 1","sku":"MNG-FRR-001"},{"id":2,"id_order":1,"id_product":11,"quantity":1,"unit_price":"85.49","name":"Frieren 1\/7 Scale Figure - Good Smile","sku":"FIG-FRR-001"}]},"timestamp":"2026-03-17 02:14:45"}


## Cancel order
PATCH {{baseUrl}}/orders/{{userId}}/1/cancel
Authorization: Bearer {{userToken}}

### Response
// {"status":"success","code":200,"msg":"Order cancelled successfully","data":null,"timestamp":"2026-03-17 02:14:55"}


## Verify stock returned after cancel
GET {{baseUrl}}/products/1
Accept: {{contentType}}

### Response
// {"status":"success","code":200,"msg":"Request success","data":{"id":1,"id_franchise":1,"product_type":"manga_volume","name":"Frieren: Beyond Journey's End Vol. 1","description":"First volume of the acclaimed manga series.","price":"12.99","discount":"0.00","stock":25,"active":1,"sku":"MNG-FRR-001","created_at":"2026-02-24 04:00:04","updated_at":"2026-03-17 02:14:55","cover_image":"https:\/\/res.cloudinary.com\/dqemjiltd\/image\/upload\/v1771988013\/fbje1_zp63jy.jpg","details":{"id_product":1,"id_publisher":3,"id_media":1,"volume":1}},"timestamp":"2026-03-17 02:15:04"}


